<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <LocalDebuggerWorkingDirectory>$(ProjectDir)</LocalDebuggerWorkingDirectory>
    <LocalDebuggerCommandArguments>-i Test.png -o Test.gmd -n Test --width 64 --height 64 --max-objects 50000</LocalDebuggerCommandArguments>
    <DebuggerFlavor>WindowsLocalDebugger</DebuggerFlavor>
    <LocalDebuggerCommandArgumentsHistory>-i Test.png -o Test.gmd -n Test --width 64 --height 64 --max-objects 50000|</LocalDebuggerCommandArgumentsHistory>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <LocalDebuggerWorkingDirectory>$(ProjectDir)</LocalDebuggerWorkingDirectory>
    <LocalDebuggerCommandArguments>-i Test.png -o Test.gmd -n Test --width 64 --height 64 --max-objects 50000</LocalDebuggerCommandArguments>
    <DebuggerFlavor>WindowsLocalDebugger</DebuggerFlavor>
    <LocalDebuggerCommandArgumentsHistory>-i Test.png -o Test.gmd -n Test --width 64 --height 64 --max-objects 50000|</LocalDebuggerCommandArgumentsHistory>
  </PropertyGroup>
</Project>